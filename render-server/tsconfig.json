{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react",
    "paths": {
      "../remotion/types": ["../remotion/types"]
    }
  },
  "include": ["server.ts", "../remotion/types.ts"],
  "exclude": ["node_modules", "dist"]
}
